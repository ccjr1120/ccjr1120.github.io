{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "composite": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
